<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_surface"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_capture_title"
        android:textColor="#12244A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/widget_capture_subtitle"
        android:textColor="#6C7A98"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/widget_capture_button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_primary"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="@string/widget_capture_button"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/widget_voice_button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_secondary"
            android:gravity="center"
            android:text="@string/widget_voice_button"
            android:textAllCaps="false"
            android:textColor="#245BB6"
            android:textStyle="bold" />

        <Button
            android:id="@+id/widget_flow_button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/widget_button_secondary"
            android:gravity="center"
            android:text="@string/widget_flow_button"
            android:textAllCaps="false"
            android:textColor="#245BB6"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
